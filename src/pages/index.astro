---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import RaffleCard from "../components/RaffleCard.astro";
import DealCard from "../components/DealCard.astro";
import { raffles } from "../data/raffles";
import { deals } from "../data/deals";

const raffleBrands = ["Todas", ...new Set(raffles.map((r) => r.brand))];
const dealBrands = ["Todas", ...new Set(deals.map((d) => d.brand))];

// Telegram y WhatsApp: canales todavía no creados. Bloque desactivado más
// abajo (comentado) hasta que existan de verdad — ver el comentario junto a
// <div class="cta"> en el HTML. Cuando tengáis los canales, descomentad
// estas dos líneas y el bloque de abajo, y poned aquí las URLs reales.
// const TELEGRAM_URL = "https://t.me/vuestro_canal";
// const WHATSAPP_URL = "https://whatsapp.com/channel/vuestro_canal";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Velzory — raffles y chollos de sneakers</title>
		<!-- Verificación de propiedad del sitio para la red de afiliados Awin -->
		<meta name="awin-verification" content="Awin" />
	</head>
	<body>
		<div class="wrap">
			<Header />

			<form class="search-bar" id="search-form">
				<input type="search" id="search-input" placeholder="Buscar por modelo o marca..." aria-label="Buscar zapatilla" />
				<button type="submit" class="search-btn">Buscar</button>
			</form>

			<section>
				<h2 class="section-title">Raffles y lanzamientos</h2>
				<div class="filters" id="raffle-filters">
					{
						raffleBrands.map((brand, i) => (
							<button type="button" class="chip" class:list={{ active: i === 0 }} data-brand={brand}>
								{brand}
							</button>
						))
					}
				</div>
				<div class="grid" id="raffle-grid">
					{raffles.map((raffle) => <RaffleCard raffle={raffle} />)}
				</div>
				<p class="empty" id="raffle-empty" hidden>No hay raffles de esa marca ahora mismo.</p>
			</section>

			<section>
				<h2 class="section-title">Chollos y ofertas</h2>
				<div class="filters" id="deal-filters">
					{
						dealBrands.map((brand, i) => (
							<button type="button" class="chip" class:list={{ active: i === 0 }} data-brand={brand}>
								{brand}
							</button>
						))
					}
				</div>
				<div class="grid" id="deal-list">
					{deals.map((deal) => <DealCard deal={deal} />)}
				</div>
				<p class="empty" id="deal-empty" hidden>No hay chollos de esa marca ahora mismo.</p>
			</section>

			{
				/* Telegram y WhatsApp: desactivado hasta que existan los canales de
				verdad (antes tenía placeholders "tu_canal_aqui" visibles). Para
				reactivarlo: descomentad las dos const TELEGRAM_URL/WHATSAPP_URL de
				arriba con las URLs reales, y descomentad este bloque entero.

				<div class="cta">
					<div class="cta-text">
						<strong>No te pierdas ningún drop</strong>
						<span>Recibe las alertas de raffles y chollos por Telegram o WhatsApp. Gratis.</span>
					</div>
					<div class="cta-buttons">
						<a class="cta-btn cta-btn-telegram" href={TELEGRAM_URL} target="_blank" rel="noopener">Telegram</a>
						<a class="cta-btn cta-btn-whatsapp" href={WHATSAPP_URL} target="_blank" rel="noopener">WhatsApp</a>
					</div>
				</div>
				*/
			}

			{
				/* Netlify Forms: al hacer build, Netlify escanea el HTML en busca de un
				<form data-netlify="true">, crea automáticamente un endpoint para él y
				guarda cada envío en el panel del sitio (pestaña "Forms"), sin backend
				propio. El honeypot "bot-field" es un campo oculto anti-spam estándar
				de Netlify: los bots lo rellenan, los humanos no lo ven. */
			}
			<form name="newsletter" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" class="email-form" id="email-form">
				<input type="hidden" name="form-name" value="newsletter" />
				<p class="honeypot"><label>No rellenes esto: <input name="bot-field" /></label></p>

				<div class="email-text">
					<strong>¿Prefieres el email?</strong>
					<span>Te avisamos de nuevos raffles y chollos sin saturarte.</span>
				</div>
				<div class="email-row">
					<input type="email" name="email" id="email-input" placeholder="tu@email.com" required aria-label="Email" />
					<button type="submit" class="email-btn">Apuntarme</button>
				</div>
				<label class="consent">
					<input type="checkbox" name="consent" required />
					<span>
						He leído y acepto la <a href="/politica-privacidad" target="_blank">Política de Privacidad</a>. Solo
						uso tu email para enviarte estas alertas.
					</span>
				</label>
				<p class="email-msg email-msg-ok" id="email-ok" hidden>¡Gracias! Ya estás en la lista.</p>
				<p class="email-msg email-msg-error" id="email-error" hidden>
					No se pudo enviar. Inténtalo de nuevo en unos segundos.
				</p>
			</form>
		</div>

		<Footer />
		<CookieBanner />

		<style>
			.wrap {
				max-width: 960px;
				margin: 0 auto;
				padding: 0 16px 48px;
			}
			.search-bar {
				margin-top: 20px;
				display: flex;
				gap: 8px;
			}
			.search-bar input {
				flex: 1;
				min-width: 0;
				font: inherit;
				font-size: 14px;
				padding: 12px 16px;
				border-radius: var(--radius);
				border: 1px solid var(--border);
				background: var(--surface);
				color: var(--text);
			}
			.search-bar input::placeholder {
				color: var(--text-3);
			}
			.search-bar input:focus {
				outline: none;
				border-color: var(--accent);
			}
			.search-btn {
				font: inherit;
				font-size: 14px;
				font-weight: 500;
				padding: 12px 20px;
				border-radius: var(--radius);
				border: none;
				background: #1a7f37;
				color: #fff;
				cursor: pointer;
				white-space: nowrap;
			}
			@media (max-width: 480px) {
				.search-btn {
					padding: 12px 16px;
				}
			}
			.section-title {
				font-size: 18px;
				font-weight: 600;
				margin: 28px 0 16px;
			}
			.filters {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				margin-bottom: 16px;
			}
			.chip {
				font: inherit;
				font-size: 12px;
				padding: 5px 12px;
				border-radius: 20px;
				cursor: pointer;
				background: var(--surface-2);
				color: var(--text-2);
				border: 1px solid transparent;
			}
			.chip.active {
				background: var(--accent-bg);
				color: var(--accent-text);
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: 14px;
			}
			.empty {
				text-align: center;
				color: var(--text-3);
				font-size: 13px;
				padding: 32px 0;
			}
			.cta {
				margin-top: 32px;
				padding: 18px;
				border-radius: 14px;
				background: var(--accent-bg);
				display: flex;
				align-items: center;
				gap: 14px;
				flex-wrap: wrap;
			}
			.cta-text {
				flex: 1;
				min-width: 200px;
			}
			.cta-text strong {
				color: var(--accent-text);
				font-size: 15px;
				display: block;
			}
			.cta-text span {
				color: var(--accent-text);
				font-size: 13px;
				opacity: 0.85;
			}
			.cta-buttons {
				display: flex;
				gap: 10px;
				flex-wrap: wrap;
			}
			.cta-btn {
				font-size: 14px;
				font-weight: 500;
				padding: 10px 18px;
				border-radius: var(--radius);
				text-decoration: none;
				white-space: nowrap;
			}
			.cta-btn-telegram {
				background: var(--accent-strong);
				color: #fff;
			}
			.cta-btn-whatsapp {
				background: var(--ok-bg);
				color: var(--ok-text);
			}
			@media (max-width: 480px) {
				.cta {
					flex-direction: column;
					align-items: stretch;
					text-align: center;
				}
				.cta-buttons {
					flex-direction: column;
				}
				.cta-btn {
					text-align: center;
				}
			}
			.honeypot {
				position: absolute;
				left: -9999px;
			}
			.email-form {
				margin-top: 14px;
				padding: 18px;
				border-radius: 14px;
				background: var(--surface);
				border: 1px solid var(--border);
			}
			.email-text strong {
				font-size: 15px;
				display: block;
				color: var(--text);
			}
			.email-text span {
				font-size: 13px;
				color: var(--text-2);
			}
			.email-row {
				display: flex;
				gap: 8px;
				margin-top: 12px;
			}
			.email-row input {
				flex: 1;
				min-width: 0;
				font: inherit;
				font-size: 14px;
				padding: 11px 14px;
				border-radius: var(--radius);
				border: 1px solid var(--border);
				background: var(--bg);
				color: var(--text);
			}
			.email-row input:focus {
				outline: none;
				border-color: var(--accent);
			}
			.email-btn {
				font: inherit;
				font-size: 14px;
				font-weight: 500;
				padding: 11px 20px;
				border-radius: var(--radius);
				border: none;
				background: var(--accent-strong);
				color: #fff;
				cursor: pointer;
				white-space: nowrap;
			}
			.consent {
				display: flex;
				align-items: flex-start;
				gap: 8px;
				margin-top: 12px;
				font-size: 12px;
				line-height: 1.5;
				color: var(--text-2);
			}
			.consent input {
				margin-top: 3px;
				flex-shrink: 0;
			}
			.consent a {
				color: var(--accent-strong);
			}
			.email-msg {
				margin-top: 10px;
				font-size: 13px;
			}
			.email-msg-ok {
				color: var(--ok-text);
			}
			.email-msg-error {
				color: var(--accent-text);
			}
			@media (max-width: 480px) {
				.email-row {
					flex-direction: column;
				}
			}
		</style>

		<script>
			const searchInput = document.getElementById("search-input") as HTMLInputElement | null;

			function setupSection(filtersId: string, itemsContainerId: string, emptyId: string) {
				const filters = document.getElementById(filtersId);
				const container = document.getElementById(itemsContainerId);
				const empty = document.getElementById(emptyId);
				if (!filters || !container || !empty) return () => {};

				const items = Array.from(container.querySelectorAll<HTMLElement>(":scope > [data-brand]"));
				let activeBrand = "Todas";

				function apply() {
					const query = (searchInput?.value ?? "").trim().toLowerCase();
					let visibleCount = 0;
					for (const item of items) {
						const matchesBrand = activeBrand === "Todas" || item.dataset.brand === activeBrand;
						const matchesSearch = query === "" || (item.dataset.search ?? "").includes(query);
						const visible = matchesBrand && matchesSearch;
						item.style.display = visible ? "" : "none";
						if (visible) visibleCount++;
					}
					empty!.hidden = visibleCount > 0;
				}

				filters.addEventListener("click", (event) => {
					const chip = (event.target as HTMLElement).closest<HTMLButtonElement>(".chip");
					if (!chip) return;

					filters.querySelectorAll(".chip").forEach((c) => c.classList.remove("active"));
					chip.classList.add("active");
					activeBrand = chip.dataset.brand ?? "Todas";
					apply();
				});

				return apply;
			}

			const applyRaffleFilter = setupSection("raffle-filters", "raffle-grid", "raffle-empty");
			const applyDealFilter = setupSection("deal-filters", "deal-list", "deal-empty");

			const searchForm = document.getElementById("search-form");

			searchForm?.addEventListener("submit", (event) => {
				event.preventDefault();
				applyRaffleFilter();
				applyDealFilter();
			});

			// si el usuario borra el texto y ya no envía el formulario, restauramos todo al vaciar el campo
			searchInput?.addEventListener("input", () => {
				if (searchInput.value.trim() === "") {
					applyRaffleFilter();
					applyDealFilter();
				}
			});

			// Envío del formulario de email por fetch, para no recargar la página.
			// Netlify crea el endpoint real al hacer build (escanea el HTML en
			// busca de data-netlify="true") y ahí es donde quedan guardados los
			// envíos. En local (npm run dev) el servidor de Astro responde 200 a
			// cualquier POST a "/", así que el formulario "parece" funcionar pero
			// no se guarda nada de verdad — solo se puede probar el envío real una
			// vez desplegado en Netlify.
			const emailForm = document.getElementById("email-form") as HTMLFormElement | null;
			const emailOk = document.getElementById("email-ok");
			const emailError = document.getElementById("email-error");

			emailForm?.addEventListener("submit", async (event) => {
				event.preventDefault();
				if (emailError) emailError.style.display = "none";

				const formData = new FormData(emailForm);
				const email = String(formData.get("email") ?? "");
				const body = new URLSearchParams(formData as unknown as Record<string, string>).toString();

				try {
					// 1) Netlify Forms: guarda el envío en el panel del sitio (queda como
					// registro/copia de seguridad aunque falle el paso 2).
					const response = await fetch("/", {
						method: "POST",
						headers: { "Content-Type": "application/x-www-form-urlencoded" },
						body,
					});
					if (!response.ok) throw new Error(`Respuesta ${response.status}`);

					// 2) Mailchimp: suscribe el email de verdad. Si esto falla (por
					// ejemplo, antes de configurar las variables de entorno en
					// Netlify) no rompemos la experiencia del usuario, porque el
					// email ya quedó a salvo en el paso 1 — solo lo dejamos en
					// consola para depurar.
					fetch("/.netlify/functions/mailchimp-signup", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ email }),
					}).catch((err) => console.error("No se pudo sincronizar con Mailchimp", err));

					emailForm.style.display = "none";
					if (emailOk) emailOk.style.display = "block";
				} catch {
					if (emailError) emailError.style.display = "block";
				}
			});
		</script>
	</body>
</html>
