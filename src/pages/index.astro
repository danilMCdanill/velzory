---
import "../styles/global.css";
import Header from "../components/Header.astro";
import RaffleCard from "../components/RaffleCard.astro";
import DealRow from "../components/DealRow.astro";
import { raffles } from "../data/raffles";
import { deals } from "../data/deals";

const raffleBrands = ["Todas", ...new Set(raffles.map((r) => r.brand))];
const dealBrands = ["Todas", ...new Set(deals.map((d) => d.brand))];

// TODO: sustituir por los enlaces reales de los canales cuando los tengáis.
const TELEGRAM_URL = "https://t.me/tu_canal_aqui";
const WHATSAPP_URL = "https://whatsapp.com/channel/tu_canal_aqui";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>DropAlert ES — raffles y chollos de sneakers</title>
	</head>
	<body>
		<div class="wrap">
			<Header />

			<section>
				<h2 class="section-title">Raffles y lanzamientos</h2>
				<div class="filters" id="raffle-filters">
					{
						raffleBrands.map((brand, i) => (
							<button type="button" class="chip" class:list={{ active: i === 0 }} data-brand={brand}>
								{brand}
							</button>
						))
					}
				</div>
				<div class="grid" id="raffle-grid">
					{raffles.map((raffle) => <RaffleCard raffle={raffle} />)}
				</div>
				<p class="empty" id="raffle-empty" hidden>No hay raffles de esa marca ahora mismo.</p>
			</section>

			<section>
				<h2 class="section-title">Chollos y ofertas</h2>
				<div class="filters" id="deal-filters">
					{
						dealBrands.map((brand, i) => (
							<button type="button" class="chip" class:list={{ active: i === 0 }} data-brand={brand}>
								{brand}
							</button>
						))
					}
				</div>
				<div class="list" id="deal-list">
					{deals.map((deal) => <DealRow deal={deal} />)}
				</div>
				<p class="empty" id="deal-empty" hidden>No hay chollos de esa marca ahora mismo.</p>
			</section>

			<div class="cta">
				<div class="cta-text">
					<strong>No te pierdas ningún drop</strong>
					<span>Recibe las alertas de raffles y chollos por Telegram o WhatsApp. Gratis.</span>
				</div>
				<div class="cta-buttons">
					<a class="cta-btn cta-btn-telegram" href={TELEGRAM_URL} target="_blank" rel="noopener">Telegram</a>
					<a class="cta-btn cta-btn-whatsapp" href={WHATSAPP_URL} target="_blank" rel="noopener">WhatsApp</a>
				</div>
			</div>
		</div>

		<style>
			.wrap {
				max-width: 960px;
				margin: 0 auto;
				padding: 0 16px 48px;
			}
			.section-title {
				font-size: 18px;
				font-weight: 600;
				margin: 28px 0 16px;
			}
			.filters {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				margin-bottom: 16px;
			}
			.chip {
				font: inherit;
				font-size: 12px;
				padding: 5px 12px;
				border-radius: 20px;
				cursor: pointer;
				background: var(--surface-2);
				color: var(--text-2);
				border: 1px solid transparent;
			}
			.chip.active {
				background: var(--accent-bg);
				color: var(--accent-text);
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: 14px;
			}
			.list {
				display: flex;
				flex-direction: column;
				gap: 10px;
			}
			.empty {
				text-align: center;
				color: var(--text-3);
				font-size: 13px;
				padding: 32px 0;
			}
			.cta {
				margin-top: 32px;
				padding: 18px;
				border-radius: 14px;
				background: var(--accent-bg);
				display: flex;
				align-items: center;
				gap: 14px;
				flex-wrap: wrap;
			}
			.cta-text {
				flex: 1;
				min-width: 200px;
			}
			.cta-text strong {
				color: var(--accent-text);
				font-size: 15px;
				display: block;
			}
			.cta-text span {
				color: var(--accent-text);
				font-size: 13px;
				opacity: 0.85;
			}
			.cta-buttons {
				display: flex;
				gap: 10px;
				flex-wrap: wrap;
			}
			.cta-btn {
				font-size: 14px;
				font-weight: 500;
				padding: 10px 18px;
				border-radius: var(--radius);
				text-decoration: none;
				white-space: nowrap;
			}
			.cta-btn-telegram {
				background: var(--accent-strong);
				color: #fff;
			}
			.cta-btn-whatsapp {
				background: var(--ok-bg);
				color: var(--ok-text);
			}
			@media (max-width: 480px) {
				.cta {
					flex-direction: column;
					align-items: stretch;
					text-align: center;
				}
				.cta-buttons {
					flex-direction: column;
				}
				.cta-btn {
					text-align: center;
				}
			}
		</style>

		<script>
			function setupFilter(filtersId: string, itemsContainerId: string, emptyId: string) {
				const filters = document.getElementById(filtersId);
				const container = document.getElementById(itemsContainerId);
				const empty = document.getElementById(emptyId);
				if (!filters || !container || !empty) return;

				const items = Array.from(container.querySelectorAll<HTMLElement>(":scope > [data-brand]"));

				filters.addEventListener("click", (event) => {
					const chip = (event.target as HTMLElement).closest<HTMLButtonElement>(".chip");
					if (!chip) return;

					filters.querySelectorAll(".chip").forEach((c) => c.classList.remove("active"));
					chip.classList.add("active");

					const brand = chip.dataset.brand;
					let visibleCount = 0;
					for (const item of items) {
						const matches = brand === "Todas" || item.dataset.brand === brand;
						item.style.display = matches ? "" : "none";
						if (matches) visibleCount++;
					}
					empty.hidden = visibleCount > 0;
				});
			}

			setupFilter("raffle-filters", "raffle-grid", "raffle-empty");
			setupFilter("deal-filters", "deal-list", "deal-empty");
		</script>
	</body>
</html>
