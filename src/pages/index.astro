---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import RaffleCard from "../components/RaffleCard.astro";
import DealCard from "../components/DealCard.astro";
import { raffles } from "../data/raffles";
import { deals } from "../data/deals";

const raffleBrands = ["Todas", ...new Set(raffles.map((r) => r.brand))];
const dealBrands = ["Todas", ...new Set(deals.map((d) => d.brand))];

// Fotos reales de producto para la tira animada del hero (sin duplicados).
const marqueeImages = [...new Set([...raffles, ...deals].map((p) => p.image).filter(Boolean))] as string[];

// Telegram y WhatsApp: canales todavía no creados. Bloque desactivado más
// abajo (comentado) hasta que existan de verdad. Cuando los tengáis,
// descomentad estas dos líneas y el bloque del HTML, y poned las URLs reales.
// const TELEGRAM_URL = "https://t.me/vuestro_canal";
// const WHATSAPP_URL = "https://whatsapp.com/channel/vuestro_canal";

const trust = [
  { icon: "✓", title: "Autenticidad garantizada", text: "Solo drops y tiendas verificadas. Cero falsificaciones." },
  { icon: "⚡", title: "Alertas al instante", text: "Entérate de cada lanzamiento antes de que se agote." },
  { icon: "€", title: "El mejor precio", text: "Comparamos tiendas para que pagues lo justo, nunca de más." },
  { icon: "◈", title: "Sin coste para ti", text: "Curamos por pasión; algunos enlaces son de afiliado." },
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			// Marca que hay JS lo antes posible: las animaciones .reveal solo se
			// ocultan bajo html.js, así que sin JS el contenido se ve directamente.
			document.documentElement.classList.add("js");
		</script>
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Velzory — Sneakers y coleccionables auténticos</title>
		<meta
			name="description"
			content="Descubre lanzamientos, raffles y los mejores precios en sneakers y coleccionables auténticos. Un solo sitio, cero ruido."
		/>
		<meta property="og:title" content="Velzory — Own the rare" />
		<meta
			property="og:description"
			content="Lanzamientos, raffles y los mejores precios en sneakers y coleccionables auténticos."
		/>
		<meta property="og:type" content="website" />
		<!-- Verificación de propiedad del sitio para la red de afiliados Awin -->
		<meta name="awin-verification" content="Awin" />
	</head>
	<body>
		<Header />

		<!-- ============ HERO ============ -->
		<section class="hero">
			<div class="container hero-inner">
				<span class="eyebrow reveal">Sneakers · Figuras de colección</span>
				<h1 class="hero-title reveal">
					Own the <span class="grad">rare.</span>
				</h1>
				<p class="hero-sub reveal">
					Descubre lanzamientos, raffles y los mejores precios en sneakers y coleccionables auténticos.
					Un solo sitio, cero ruido.
				</p>
				<div class="hero-cta reveal">
					<a class="btn btn-primary" href="#drops">Explorar drops</a>
					<a class="btn btn-ghost" href="#newsletter">Únete a la lista</a>
				</div>
				<div class="hero-stats reveal">
					<div class="stat"><strong>100%</strong><span>Verificado</span></div>
					<div class="stat-sep"></div>
					<div class="stat"><strong>Semanal</strong><span>Nuevos drops</span></div>
					<div class="stat-sep"></div>
					<div class="stat"><strong>0 €</strong><span>Para ti</span></div>
				</div>
			</div>

			{
				marqueeImages.length > 0 && (
					<div class="marquee" aria-hidden="true">
						<div class="marquee-track">
							{[...marqueeImages, ...marqueeImages].map((src) => (
								<div class="marquee-item" style={`background-image:url('${src}')`} />
							))}
						</div>
					</div>
				)
			}
		</section>

		<main class="container">
			<!-- ============ BUSCADOR + DROPS ============ -->
			<section id="drops" class="section">
				<div class="section-head reveal">
					<div>
						<span class="eyebrow">Lo último</span>
						<h2 class="section-title">Lanzamientos & raffles</h2>
					</div>
					<form class="search-bar" id="search-form" role="search">
						<input
							type="search"
							id="search-input"
							placeholder="Buscar por modelo o marca…"
							aria-label="Buscar zapatilla"
						/>
						<button type="submit" class="search-btn" aria-label="Buscar">Buscar</button>
					</form>
				</div>

				<div class="filters reveal" id="raffle-filters">
					{
						raffleBrands.map((brand, i) => (
							<button type="button" class="chip" class:list={{ active: i === 0 }} data-brand={brand}>
								{brand}
							</button>
						))
					}
				</div>
				<div class="grid reveal" id="raffle-grid">
					{raffles.map((raffle) => <RaffleCard raffle={raffle} />)}
				</div>
				<p class="empty" id="raffle-empty" hidden>No hay raffles de esa marca ahora mismo.</p>
			</section>

			<!-- ============ CHOLLOS ============ -->
			<section class="section">
				<div class="section-head reveal">
					<div>
						<span class="eyebrow">Most wanted</span>
						<h2 class="section-title">Chollos verificados</h2>
					</div>
				</div>
				<div class="filters reveal" id="deal-filters">
					{
						dealBrands.map((brand, i) => (
							<button type="button" class="chip" class:list={{ active: i === 0 }} data-brand={brand}>
								{brand}
							</button>
						))
					}
				</div>
				<div class="grid reveal" id="deal-list">
					{deals.map((deal) => <DealCard deal={deal} />)}
				</div>
				<p class="empty" id="deal-empty" hidden>No hay chollos de esa marca ahora mismo.</p>
			</section>

			<!-- ============ POR QUÉ VELZORY ============ -->
			<section class="section why">
				<div class="section-head reveal">
					<div>
						<span class="eyebrow">La diferencia</span>
						<h2 class="section-title">Por qué Velzory</h2>
					</div>
				</div>
				<div class="why-grid">
					{
						trust.map((t) => (
							<div class="why-card reveal">
								<span class="why-icon">{t.icon}</span>
								<h3>{t.title}</h3>
								<p>{t.text}</p>
							</div>
						))
					}
				</div>
			</section>

			{
				/* Telegram y WhatsApp: desactivado hasta que existan los canales de
				verdad. Para reactivarlo: descomentad las dos const de arriba con las
				URLs reales, y este bloque entero.

				<div class="channels">
					<a href={TELEGRAM_URL} target="_blank" rel="noopener">Telegram</a>
					<a href={WHATSAPP_URL} target="_blank" rel="noopener">WhatsApp</a>
				</div>
				*/
			}

			<!-- ============ NEWSLETTER (registro) ============ -->
			<section id="newsletter" class="section">
				<div class="newsletter reveal">
					<div class="newsletter-copy">
						<span class="eyebrow" style="color:#fff;opacity:.7">Únete al círculo</span>
						<h2>No te pierdas ningún drop.</h2>
						<p>Alertas de lanzamientos, raffles y chollos directas a tu correo. Sin spam, cuando importa.</p>
					</div>

					{
						/* Netlify Forms: al hacer build, Netlify escanea el HTML en busca de un
						<form data-netlify="true">, crea automáticamente un endpoint para él y
						guarda cada envío en el panel del sitio (pestaña "Forms"), sin backend
						propio. El honeypot "bot-field" es un campo oculto anti-spam. */
					}
					<form
						name="newsletter"
						method="POST"
						data-netlify="true"
						data-netlify-honeypot="bot-field"
						class="email-form"
						id="email-form"
					>
						<input type="hidden" name="form-name" value="newsletter" />
						<p class="honeypot"><label>No rellenes esto: <input name="bot-field" /></label></p>

						<div class="email-row">
							<input
								type="email"
								name="email"
								id="email-input"
								placeholder="tu@email.com"
								required
								aria-label="Email"
							/>
							<button type="submit" class="email-btn">Apuntarme</button>
						</div>
						<label class="consent">
							<input type="checkbox" name="consent" required />
							<span>
								He leído y acepto la <a href="/politica-privacidad" target="_blank">Política de Privacidad</a>.
								Solo uso tu email para enviarte estas alertas.
							</span>
						</label>
						<p class="email-msg email-msg-ok" id="email-ok" hidden>¡Gracias! Ya estás en la lista.</p>
						<p class="email-msg email-msg-error" id="email-error" hidden>
							No se pudo enviar. Inténtalo de nuevo en unos segundos.
						</p>
					</form>
				</div>
			</section>
		</main>

		<Footer />
		<CookieBanner />

		<style>
			/* ---------- HERO ---------- */
			.hero {
				position: relative;
				overflow: hidden;
				padding-top: 72px;
				background:
					radial-gradient(60% 90% at 50% -10%, rgba(30, 80, 255, 0.10), transparent 60%),
					var(--bg);
			}
			.hero-inner {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				padding-bottom: 56px;
			}
			.hero-title {
				font-size: clamp(48px, 9vw, 104px);
				font-weight: 800;
				letter-spacing: -0.04em;
				margin: 18px 0 0;
			}
			.hero-title .grad {
				background: linear-gradient(100deg, var(--accent), #6a8bff);
				-webkit-background-clip: text;
				background-clip: text;
				color: transparent;
			}
			.hero-sub {
				max-width: 560px;
				margin: 22px auto 0;
				font-size: clamp(16px, 2.2vw, 19px);
				color: var(--text-2);
				line-height: 1.6;
			}
			.hero-cta {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				justify-content: center;
				margin-top: 32px;
			}
			.hero-stats {
				display: flex;
				align-items: center;
				gap: 22px;
				margin-top: 44px;
			}
			.stat {
				display: flex;
				flex-direction: column;
			}
			.stat strong {
				font-size: 20px;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.stat span {
				font-size: 12px;
				color: var(--text-3);
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}
			.stat-sep {
				width: 1px;
				height: 30px;
				background: var(--border);
			}

			/* Tira animada de producto */
			.marquee {
				margin-top: 8px;
				-webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
				mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
				overflow: hidden;
			}
			.marquee-track {
				display: flex;
				gap: 16px;
				width: max-content;
				padding: 8px 0 40px;
				animation: marquee 42s linear infinite;
			}
			.marquee:hover .marquee-track {
				animation-play-state: paused;
			}
			.marquee-item {
				width: 200px;
				height: 150px;
				flex-shrink: 0;
				border-radius: var(--radius);
				background-color: var(--surface-2);
				background-size: contain;
				background-repeat: no-repeat;
				background-position: center;
				background-blend-mode: multiply;
				border: 1px solid var(--border);
			}
			@keyframes marquee {
				to {
					transform: translateX(calc(-50% - 8px));
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.marquee-track {
					animation: none;
				}
			}

			/* ---------- SECCIONES ---------- */
			.section {
				padding: 72px 0 0;
			}
			.section-head {
				display: flex;
				align-items: flex-end;
				justify-content: space-between;
				gap: 20px;
				flex-wrap: wrap;
				margin-bottom: 28px;
			}
			.section-title {
				font-size: clamp(26px, 4vw, 38px);
				font-weight: 700;
				margin-top: 6px;
			}

			/* Buscador */
			.search-bar {
				display: flex;
				gap: 8px;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 999px;
				padding: 6px 6px 6px 8px;
				box-shadow: var(--shadow-sm);
				transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
			}
			.search-bar:focus-within {
				border-color: var(--accent);
				box-shadow: 0 0 0 4px var(--accent-bg);
			}
			.search-bar input {
				flex: 1;
				min-width: 200px;
				font: inherit;
				font-size: 14px;
				padding: 8px 12px;
				border: none;
				background: transparent;
				color: var(--text);
			}
			.search-bar input:focus {
				outline: none;
			}
			.search-bar input::placeholder {
				color: var(--text-3);
			}
			.search-btn {
				font: inherit;
				font-size: 14px;
				font-weight: 600;
				padding: 9px 20px;
				border-radius: 999px;
				border: none;
				background: var(--text);
				color: #fff;
				cursor: pointer;
				white-space: nowrap;
				transition: background var(--dur-fast) var(--ease);
			}
			.search-btn:hover {
				background: var(--accent);
			}

			/* Filtros (chips) */
			.filters {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				margin-bottom: 24px;
			}
			.chip {
				font: inherit;
				font-size: 13px;
				font-weight: 500;
				padding: 8px 16px;
				border-radius: 999px;
				cursor: pointer;
				background: var(--surface);
				color: var(--text-2);
				border: 1px solid var(--border);
				transition: all var(--dur-fast) var(--ease);
			}
			.chip:hover {
				border-color: var(--text);
				color: var(--text);
			}
			.chip.active {
				background: var(--text);
				color: #fff;
				border-color: var(--text);
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(272px, 1fr));
				gap: 20px;
			}
			.empty {
				text-align: center;
				color: var(--text-3);
				font-size: 14px;
				padding: 48px 0;
			}

			/* ---------- POR QUÉ VELZORY ---------- */
			.why-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 20px;
			}
			.why-card {
				padding: 28px;
				border: 1px solid var(--border);
				border-radius: var(--radius);
				background: var(--surface);
				transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
			}
			.why-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--shadow-lg);
			}
			.why-icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 46px;
				height: 46px;
				border-radius: 12px;
				background: var(--accent-bg);
				color: var(--accent);
				font-size: 20px;
				font-weight: 700;
				margin-bottom: 16px;
			}
			.why-card h3 {
				font-size: 17px;
				font-weight: 700;
				margin-bottom: 8px;
			}
			.why-card p {
				font-size: 14px;
				color: var(--text-2);
				line-height: 1.6;
			}

			/* ---------- NEWSLETTER ---------- */
			.newsletter {
				position: relative;
				overflow: hidden;
				border-radius: var(--radius-lg);
				padding: clamp(32px, 5vw, 64px);
				background:
					radial-gradient(80% 140% at 100% 0%, rgba(106, 139, 255, 0.35), transparent 55%),
					#0a0a0b;
				color: #fff;
				display: grid;
				grid-template-columns: 1.1fr 1fr;
				gap: 40px;
				align-items: center;
			}
			.newsletter-copy h2 {
				color: #fff;
				font-size: clamp(26px, 3.5vw, 40px);
				margin: 10px 0 12px;
			}
			.newsletter-copy p {
				color: rgba(255, 255, 255, 0.7);
				font-size: 15px;
				line-height: 1.6;
				max-width: 380px;
			}
			.honeypot {
				position: absolute;
				left: -9999px;
			}
			.email-row {
				display: flex;
				gap: 8px;
				background: rgba(255, 255, 255, 0.08);
				border: 1px solid rgba(255, 255, 255, 0.16);
				border-radius: 999px;
				padding: 6px 6px 6px 8px;
			}
			.email-row:focus-within {
				border-color: var(--accent);
				box-shadow: 0 0 0 4px rgba(30, 80, 255, 0.3);
			}
			.email-row input {
				flex: 1;
				min-width: 0;
				font: inherit;
				font-size: 15px;
				padding: 10px 14px;
				border: none;
				background: transparent;
				color: #fff;
			}
			.email-row input::placeholder {
				color: rgba(255, 255, 255, 0.5);
			}
			.email-row input:focus {
				outline: none;
			}
			.email-btn {
				font: inherit;
				font-size: 15px;
				font-weight: 600;
				padding: 11px 24px;
				border-radius: 999px;
				border: none;
				background: var(--accent);
				color: #fff;
				cursor: pointer;
				white-space: nowrap;
				transition: background var(--dur-fast) var(--ease);
			}
			.email-btn:hover {
				background: #3d68ff;
			}
			.consent {
				display: flex;
				align-items: flex-start;
				gap: 8px;
				margin-top: 14px;
				font-size: 12px;
				line-height: 1.5;
				color: rgba(255, 255, 255, 0.6);
			}
			.consent input {
				margin-top: 3px;
				flex-shrink: 0;
				accent-color: var(--accent);
			}
			.consent a {
				color: #fff;
				text-decoration: underline;
			}
			.email-msg {
				margin-top: 12px;
				font-size: 14px;
				font-weight: 500;
			}
			.email-msg-ok {
				color: #4ade80;
			}
			.email-msg-error {
				color: #ff8b8b;
			}

			@media (max-width: 760px) {
				.newsletter {
					grid-template-columns: 1fr;
					gap: 24px;
				}
				.hero-stats {
					gap: 16px;
				}
			}
			@media (max-width: 520px) {
				.email-row {
					flex-direction: column;
					border-radius: var(--radius);
					padding: 10px;
				}
				.email-btn {
					width: 100%;
				}
				.section-head {
					align-items: flex-start;
				}
				.search-bar {
					width: 100%;
				}
			}
		</style>

		<script>
			const searchInput = document.getElementById("search-input") as HTMLInputElement | null;

			function setupSection(filtersId: string, itemsContainerId: string, emptyId: string) {
				const filters = document.getElementById(filtersId);
				const container = document.getElementById(itemsContainerId);
				const empty = document.getElementById(emptyId);
				if (!filters || !container || !empty) return () => {};

				const items = Array.from(container.querySelectorAll<HTMLElement>(":scope > [data-brand]"));
				let activeBrand = "Todas";

				function apply() {
					const query = (searchInput?.value ?? "").trim().toLowerCase();
					let visibleCount = 0;
					for (const item of items) {
						const matchesBrand = activeBrand === "Todas" || item.dataset.brand === activeBrand;
						const matchesSearch = query === "" || (item.dataset.search ?? "").includes(query);
						const visible = matchesBrand && matchesSearch;
						item.style.display = visible ? "" : "none";
						if (visible) visibleCount++;
					}
					empty!.hidden = visibleCount > 0;
				}

				filters.addEventListener("click", (event) => {
					const chip = (event.target as HTMLElement).closest<HTMLButtonElement>(".chip");
					if (!chip) return;

					filters.querySelectorAll(".chip").forEach((c) => c.classList.remove("active"));
					chip.classList.add("active");
					activeBrand = chip.dataset.brand ?? "Todas";
					apply();
				});

				return apply;
			}

			const applyRaffleFilter = setupSection("raffle-filters", "raffle-grid", "raffle-empty");
			const applyDealFilter = setupSection("deal-filters", "deal-list", "deal-empty");

			const searchForm = document.getElementById("search-form");

			searchForm?.addEventListener("submit", (event) => {
				event.preventDefault();
				applyRaffleFilter();
				applyDealFilter();
			});

			// si el usuario borra el texto y ya no envía el formulario, restauramos todo al vaciar el campo
			searchInput?.addEventListener("input", () => {
				if (searchInput.value.trim() === "") {
					applyRaffleFilter();
					applyDealFilter();
				}
			});

			// Envío del formulario de email por fetch, para no recargar la página.
			// Netlify crea el endpoint real al hacer build (escanea el HTML en
			// busca de data-netlify="true") y ahí es donde quedan guardados los
			// envíos. En local (npm run dev) el servidor de Astro responde 200 a
			// cualquier POST a "/", así que el formulario "parece" funcionar pero
			// no se guarda nada de verdad — solo se puede probar el envío real una
			// vez desplegado en Netlify.
			const emailForm = document.getElementById("email-form") as HTMLFormElement | null;
			const emailOk = document.getElementById("email-ok");
			const emailError = document.getElementById("email-error");

			emailForm?.addEventListener("submit", async (event) => {
				event.preventDefault();
				if (emailError) emailError.style.display = "none";

				const formData = new FormData(emailForm);
				const email = String(formData.get("email") ?? "");
				const body = new URLSearchParams(formData as unknown as Record<string, string>).toString();

				try {
					// 1) Netlify Forms: guarda el envío en el panel del sitio (queda como
					// registro/copia de seguridad aunque falle el paso 2).
					const response = await fetch("/", {
						method: "POST",
						headers: { "Content-Type": "application/x-www-form-urlencoded" },
						body,
					});
					if (!response.ok) throw new Error(`Respuesta ${response.status}`);

					// 2) Mailchimp: suscribe el email de verdad. Si esto falla (por
					// ejemplo, antes de configurar las variables de entorno en
					// Netlify) no rompemos la experiencia del usuario, porque el
					// email ya quedó a salvo en el paso 1 — solo lo dejamos en
					// consola para depurar.
					fetch("/.netlify/functions/mailchimp-signup", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ email }),
					}).catch((err) => console.error("No se pudo sincronizar con Mailchimp", err));

					emailForm.style.display = "none";
					if (emailOk) emailOk.style.display = "block";
				} catch {
					if (emailError) emailError.style.display = "block";
				}
			});
		</script>
	</body>
</html>
