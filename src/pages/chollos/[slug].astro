---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CookieBanner from "../../components/CookieBanner.astro";
import { deals } from "../../data/deals";
import type { Deal } from "../../data/types";

export function getStaticPaths() {
  return deals.map((deal) => ({
    params: { slug: deal.slug },
    props: { deal },
  }));
}

interface Props {
  deal: Deal;
}

const { deal } = Astro.props;

const related = deals.filter((d) => d.brand === deal.brand && d.slug !== deal.slug).slice(0, 3);
const images = deal.images && deal.images.length > 0 ? deal.images : deal.image ? [deal.image] : [];
const specs = [
  deal.styleCode && { label: "Código de estilo", value: deal.styleCode },
  deal.colorway && { label: "Colorway", value: deal.colorway },
  deal.sizes && { label: "Tallas", value: deal.sizes },
].filter(Boolean) as { label: string; value: string }[];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<script is:inline>document.documentElement.classList.add("js");</script>
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{deal.title} — Velzory</title>
		{deal.description && <meta name="description" content={deal.description} />}
		<meta property="og:title" content={`${deal.title} — Velzory`} />
		{deal.image && <meta property="og:image" content={deal.image} />}
	</head>
	<body>
		<Header />

		<main class="container detail">
			<nav class="crumbs" aria-label="Migas de pan">
				<a href="/">Inicio</a>
				<span>/</span>
				<a href="/#drops">Chollos</a>
				<span>/</span>
				<span class="crumb-current">{deal.title}</span>
			</nav>

			<div class="product">
				<!-- Galería -->
				<div class="gallery reveal">
					{
						images.length > 0 ? (
							images.map((img) => <div class="gallery-img" style={`background-image:url('${img}')`} />)
						) : (
							<div class="gallery-img gallery-placeholder">👟</div>
						)
					}
				</div>

				<!-- Panel -->
				<div class="panel reveal">
					<span class="eyebrow">{deal.brand}</span>
					<h1>{deal.title}</h1>

					<div class="price-row">
						<span class="price">{deal.newPrice}</span>
						<span class="old-price">{deal.oldPrice}</span>
						<span class="disc">{deal.discount}</span>
					</div>

					{deal.description && <p class="description">{deal.description}</p>}

					{
						specs.length > 0 && (
							<dl class="specs">
								{specs.map((s) => (
									<div class="spec">
										<dt>{s.label}</dt>
										<dd>{s.value}</dd>
									</div>
								))}
							</dl>
						)
					}

					<div class="buy">
						<a
							class="btn btn-buy"
							href={deal.url}
							target="_blank"
							rel={deal.affiliate ? "sponsored noopener" : "noopener"}
						>
							Ver oferta en {deal.store} ↗
						</a>
						<p class="buy-note">
							Precio más bajo en <strong>{deal.store}</strong>.
							{deal.affiliate ? " Enlace de afiliado, sin coste extra para ti." : " Enlace directo a la tienda."}
						</p>
					</div>
				</div>
			</div>

			{
				related.length > 0 && (
					<section class="related reveal">
						<h2 class="related-title">Más de {deal.brand}</h2>
						<div class="related-grid">
							{related.map((d) => (
								<a class="related-card" href={`/chollos/${d.slug}/`}>
									<div
										class="related-img"
										style={d.image ? `background-image:url('${d.image}')` : undefined}
									>
										{!d.image && "👟"}
									</div>
									<div class="related-body">
										<span class="related-name">{d.title}</span>
										<span class="related-sub">{d.brand} · {d.newPrice}</span>
									</div>
								</a>
							))}
						</div>
					</section>
				)
			}
		</main>

		<Footer />
		<CookieBanner />

		<style>
			.detail {
				padding-top: 32px;
			}
			.crumbs {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 8px;
				font-size: 13px;
				color: var(--text-3);
				margin-bottom: 28px;
			}
			.crumbs a {
				color: var(--text-2);
				text-decoration: none;
			}
			.crumbs a:hover {
				color: var(--accent);
			}
			.crumb-current {
				color: var(--text);
			}

			.product {
				display: grid;
				grid-template-columns: 1.15fr 1fr;
				gap: 48px;
				align-items: start;
			}

			.gallery {
				display: grid;
				grid-template-columns: 1fr;
				gap: 12px;
				position: sticky;
				top: 92px;
			}
			.gallery-img {
				aspect-ratio: 4 / 3;
				border-radius: var(--radius-lg);
				background-color: var(--surface-2);
				background-size: contain;
				background-repeat: no-repeat;
				background-position: center;
				background-blend-mode: multiply;
				border: 1px solid var(--border);
			}
			.gallery-placeholder {
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 72px;
			}

			.panel h1 {
				font-size: clamp(28px, 4vw, 40px);
				margin: 10px 0 0;
			}
			.price-row {
				display: flex;
				align-items: baseline;
				flex-wrap: wrap;
				gap: 14px;
				margin-top: 18px;
			}
			.price {
				font-size: 34px;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.old-price {
				font-size: 18px;
				color: var(--text-3);
				text-decoration: line-through;
			}
			.disc {
				font-size: 13px;
				font-weight: 700;
				padding: 5px 12px;
				border-radius: 999px;
				background: var(--text);
				color: #fff;
			}
			.description {
				margin-top: 20px;
				font-size: 15px;
				color: var(--text-2);
				line-height: 1.7;
			}
			.specs {
				margin-top: 24px;
				border-top: 1px solid var(--border);
			}
			.spec {
				display: flex;
				justify-content: space-between;
				gap: 16px;
				padding: 13px 0;
				border-bottom: 1px solid var(--border);
			}
			.spec dt {
				font-size: 14px;
				color: var(--text-3);
			}
			.spec dd {
				font-size: 14px;
				font-weight: 600;
				text-align: right;
			}

			.buy {
				margin-top: 28px;
			}
			.btn-buy {
				width: 100%;
				background: var(--text);
				color: #fff;
				font-size: 16px;
				padding: 16px 24px;
			}
			.btn-buy:hover {
				background: var(--accent);
				box-shadow: 0 10px 28px rgba(30, 80, 255, 0.28);
			}
			.buy-note {
				margin-top: 12px;
				font-size: 13px;
				color: var(--text-3);
				text-align: center;
			}
			.buy-note strong {
				color: var(--text-2);
			}

			.related {
				margin-top: 80px;
			}
			.related-title {
				font-size: clamp(22px, 3vw, 30px);
				margin-bottom: 24px;
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 18px;
			}
			.related-card {
				border: 1px solid var(--border);
				border-radius: var(--radius);
				overflow: hidden;
				text-decoration: none;
				background: var(--surface);
				transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
			}
			.related-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--shadow-lg);
			}
			.related-img {
				height: 150px;
				background-color: var(--surface-2);
				background-size: contain;
				background-repeat: no-repeat;
				background-position: center;
				background-blend-mode: multiply;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 30px;
			}
			.related-body {
				padding: 14px;
				display: flex;
				flex-direction: column;
				gap: 3px;
			}
			.related-name {
				font-size: 14px;
				font-weight: 700;
				color: var(--text);
			}
			.related-sub {
				font-size: 13px;
				color: var(--text-3);
			}

			@media (max-width: 860px) {
				.product {
					grid-template-columns: 1fr;
					gap: 28px;
				}
				.gallery {
					position: static;
				}
			}
		</style>
	</body>
</html>
