---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CookieBanner from "../../components/CookieBanner.astro";
import StoreList from "../../components/StoreList.astro";
import { raffles } from "../../data/raffles";
import type { Raffle } from "../../data/types";

export function getStaticPaths() {
  return raffles.map((raffle) => ({
    params: { slug: raffle.slug },
    props: { raffle },
  }));
}

interface Props {
  raffle: Raffle;
}

const { raffle } = Astro.props;

const related = raffles.filter((r) => r.brand === raffle.brand && r.slug !== raffle.slug).slice(0, 3);
const images = raffle.images && raffle.images.length > 0 ? raffle.images : raffle.image ? [raffle.image] : [];
const specs = [
  raffle.styleCode && { label: "Código de estilo", value: raffle.styleCode },
  raffle.colorway && { label: "Colorway", value: raffle.colorway },
  raffle.sizes && { label: "Tallas", value: raffle.sizes },
].filter(Boolean) as { label: string; value: string }[];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<script is:inline>document.documentElement.classList.add("js");</script>
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{raffle.title} — Velzory</title>
		{raffle.description && <meta name="description" content={raffle.description} />}
		<meta property="og:title" content={`${raffle.title} — Velzory`} />
		{raffle.image && <meta property="og:image" content={raffle.image} />}
	</head>
	<body>
		<Header />

		<main class="container detail">
			<nav class="crumbs" aria-label="Migas de pan">
				<a href="/">Inicio</a>
				<span>/</span>
				<a href="/#drops">Raffles</a>
				<span>/</span>
				<span class="crumb-current">{raffle.title}</span>
			</nav>

			<div class="product">
				<!-- Galería -->
				<div class="gallery reveal">
					{
						images.length > 0 ? (
							images.map((img) => <div class="gallery-img" style={`background-image:url('${img}')`} />)
						) : (
							<div class="gallery-img gallery-placeholder">👟</div>
						)
					}
				</div>

				<!-- Panel de info -->
				<div class="panel reveal">
					<span class="eyebrow">{raffle.brand}</span>
					<h1>{raffle.title}</h1>

					<div class="price-row">
						<span class="price">{raffle.price}</span>
						<span class:list={["badge", raffle.status.type]}>{raffle.status.text}</span>
					</div>

					{raffle.description && <p class="description">{raffle.description}</p>}

					{
						specs.length > 0 && (
							<dl class="specs">
								{specs.map((s) => (
									<div class="spec">
										<dt>{s.label}</dt>
										<dd>{s.value}</dd>
									</div>
								))}
							</dl>
						)
					}

					<div class="stores-block">
						<div class="stores-head">
							<h2>Dónde participar</h2>
							<span class="badge-verified">✓ Tiendas verificadas</span>
						</div>
						<StoreList stores={raffle.stores} />
						<p class="stores-note">
							Solo listamos tiendas oficiales o de confianza. Algunos enlaces son de afiliado, sin coste extra
							para ti.
						</p>
					</div>
				</div>
			</div>

			{
				related.length > 0 && (
					<section class="related reveal">
						<h2 class="related-title">Más de {raffle.brand}</h2>
						<div class="related-grid">
							{related.map((r) => (
								<a class="related-card" href={`/raffles/${r.slug}/`}>
									<div
										class="related-img"
										style={r.image ? `background-image:url('${r.image}')` : undefined}
									>
										{!r.image && "👟"}
									</div>
									<div class="related-body">
										<span class="related-name">{r.title}</span>
										<span class="related-sub">{r.brand} · {r.price}</span>
									</div>
								</a>
							))}
						</div>
					</section>
				)
			}
		</main>

		<Footer />
		<CookieBanner />

		<style>
			.detail {
				padding-top: 32px;
			}
			.crumbs {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 8px;
				font-size: 13px;
				color: var(--text-3);
				margin-bottom: 28px;
			}
			.crumbs a {
				color: var(--text-2);
				text-decoration: none;
			}
			.crumbs a:hover {
				color: var(--accent);
			}
			.crumb-current {
				color: var(--text);
			}

			.product {
				display: grid;
				grid-template-columns: 1.15fr 1fr;
				gap: 48px;
				align-items: start;
			}

			/* Galería */
			.gallery {
				display: grid;
				grid-template-columns: 1fr;
				gap: 12px;
				position: sticky;
				top: 92px;
			}
			.gallery-img {
				aspect-ratio: 4 / 3;
				border-radius: var(--radius-lg);
				background-color: var(--surface-2);
				background-size: contain;
				background-repeat: no-repeat;
				background-position: center;
				background-blend-mode: multiply;
				border: 1px solid var(--border);
			}
			.gallery-placeholder {
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 72px;
			}

			/* Panel */
			.panel h1 {
				font-size: clamp(28px, 4vw, 40px);
				margin: 10px 0 0;
			}
			.price-row {
				display: flex;
				align-items: center;
				gap: 14px;
				margin-top: 18px;
			}
			.price {
				font-size: 30px;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.badge {
				font-size: 12px;
				font-weight: 600;
				padding: 5px 12px;
				border-radius: 999px;
				white-space: nowrap;
			}
			.badge.warn {
				background: var(--warn-bg);
				color: var(--warn-text);
			}
			.badge.accent {
				background: var(--accent-bg);
				color: var(--accent-text);
			}
			.description {
				margin-top: 20px;
				font-size: 15px;
				color: var(--text-2);
				line-height: 1.7;
			}
			.specs {
				margin-top: 24px;
				border-top: 1px solid var(--border);
			}
			.spec {
				display: flex;
				justify-content: space-between;
				gap: 16px;
				padding: 13px 0;
				border-bottom: 1px solid var(--border);
			}
			.spec dt {
				font-size: 14px;
				color: var(--text-3);
			}
			.spec dd {
				font-size: 14px;
				font-weight: 600;
				text-align: right;
			}

			.stores-block {
				margin-top: 28px;
				padding: 22px;
				border: 1px solid var(--border);
				border-radius: var(--radius);
				background: var(--bg-soft);
			}
			.stores-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 12px;
				margin-bottom: 16px;
			}
			.stores-head h2 {
				font-size: 17px;
				font-weight: 700;
			}
			.stores-note {
				margin-top: 14px;
				font-size: 12px;
				color: var(--text-3);
				line-height: 1.5;
			}

			/* Relacionados */
			.related {
				margin-top: 80px;
			}
			.related-title {
				font-size: clamp(22px, 3vw, 30px);
				margin-bottom: 24px;
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 18px;
			}
			.related-card {
				border: 1px solid var(--border);
				border-radius: var(--radius);
				overflow: hidden;
				text-decoration: none;
				background: var(--surface);
				transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
			}
			.related-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--shadow-lg);
			}
			.related-img {
				height: 150px;
				background-color: var(--surface-2);
				background-size: contain;
				background-repeat: no-repeat;
				background-position: center;
				background-blend-mode: multiply;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 30px;
			}
			.related-body {
				padding: 14px;
				display: flex;
				flex-direction: column;
				gap: 3px;
			}
			.related-name {
				font-size: 14px;
				font-weight: 700;
				color: var(--text);
			}
			.related-sub {
				font-size: 13px;
				color: var(--text-3);
			}

			@media (max-width: 860px) {
				.product {
					grid-template-columns: 1fr;
					gap: 28px;
				}
				.gallery {
					position: static;
				}
			}
		</style>
	</body>
</html>
