---
import type { Store } from "../data/types";

interface Props {
  stores: Store[];
}

const { stores } = Astro.props;
---

<div class="stores">
  {
    stores.map((store) => (
      <a
        class="store-row"
        href={store.url}
        target="_blank"
        rel={store.affiliate ? "sponsored noopener" : "noopener"}
      >
        <span class="store-name">{store.name}</span>
        <span class="store-meta">
          <span class="tag">{store.affiliate ? "Afiliado" : "Enlace directo"}</span>
          <span class="arrow">↗</span>
        </span>
      </a>
    ))
  }
</div>

<style>
  .stores {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .store-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    text-decoration: none;
    transition:
      border-color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease),
      transform var(--dur-fast) var(--ease);
  }
  .store-row:hover {
    border-color: var(--text);
    transform: translateX(2px);
  }
  .store-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .store-meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .tag {
    font-size: 11px;
    color: var(--text-3);
  }
  .arrow {
    font-size: 14px;
    color: var(--text-2);
    transition: transform var(--dur-fast) var(--ease);
  }
  .store-row:hover .arrow {
    transform: translate(2px, -2px);
    color: var(--accent);
  }
</style>
