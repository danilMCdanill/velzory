---
import type { Store } from "../data/types";

interface Props {
  stores: Store[];
}

const { stores } = Astro.props;
---

<div class="stores">
  <p class="stores-label">Disponible en:</p>
  {
    stores.map((store) => (
      <div class="store-row">
        <a class="store-name" href={store.url} target="_blank" rel={store.affiliate ? "sponsored noopener" : "noopener"}>
          {store.name}
        </a>
        {store.affiliate ? <span class="aff">Afiliado</span> : <span class="no-aff">Enlace directo</span>}
      </div>
    ))
  }
</div>

<style>
  .stores {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .stores-label {
    font-size: 12px;
    color: var(--text-3);
    margin-bottom: 8px;
  }
  .store-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 7px;
  }
  .store-row:last-child {
    margin-bottom: 0;
  }
  .store-name {
    font-size: 13px;
    color: var(--text);
    text-decoration: none;
  }
  .store-name:hover {
    text-decoration: underline;
  }
  .aff {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 5px;
    background: var(--ok-bg);
    color: var(--ok-text);
  }
  .no-aff {
    font-size: 11px;
    color: var(--text-3);
  }
</style>
