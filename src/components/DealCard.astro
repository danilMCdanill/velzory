---
import type { Deal } from "../data/types";

interface Props {
  deal: Deal;
}

const { deal } = Astro.props;
---

<div class="card" data-brand={deal.brand} data-search={`${deal.title} ${deal.brand}`.toLowerCase()}>
  <a class="card-img" href={`/chollos/${deal.slug}/`} style={deal.image ? `background-image:url('${deal.image}')` : undefined}>
    {!deal.image && "👟"}
  </a>
  <div class="card-body">
    <a class="card-title" href={`/chollos/${deal.slug}/`}>{deal.title}</a>
    <p class="card-sub">{deal.brand}</p>

    <div class="prices">
      <span class="old-price">{deal.oldPrice}</span>
      <span class="new-price">{deal.newPrice}</span>
      <span class="disc">{deal.discount}</span>
    </div>

    <p class="cheapest">Más barato en <strong>{deal.store}</strong></p>

    <div class="card-action">
      {
        /* Botón de compra: hoy enlaza directo a la tienda (deal.url). Cuando
        tengáis contratos de afiliados reales, aquí es donde iría el enlace
        de afiliado (o los parámetros de tracking) en vez de la URL directa. */
      }
      <a class="btn" href={deal.url} target="_blank" rel={deal.affiliate ? "sponsored noopener" : "noopener"}>
        Comprar ↗
      </a>
      {deal.affiliate ? <span class="aff">Afiliado</span> : <span class="no-aff">Enlace directo</span>}
    </div>
  </div>
</div>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .card-img {
    height: 130px;
    background: var(--surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    background-blend-mode: multiply;
    text-decoration: none;
  }
  .card-body {
    padding: 14px;
  }
  .card-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    display: block;
  }
  .card-title:hover {
    text-decoration: underline;
  }
  .card-sub {
    font-size: 13px;
    color: var(--text-2);
    margin-top: 2px;
  }
  .prices {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
  }
  .old-price {
    font-size: 13px;
    color: var(--text-3);
    text-decoration: line-through;
  }
  .new-price {
    font-size: 18px;
    font-weight: 600;
    color: var(--ok-text);
  }
  .disc {
    font-size: 11px;
    padding: 2px 7px;
    border-radius: 5px;
    background: var(--ok-bg);
    color: var(--ok-text);
  }
  .cheapest {
    font-size: 12px;
    color: var(--text-2);
    margin-top: 6px;
  }
  .cheapest strong {
    color: var(--text);
  }
  .card-action {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
  }
  .btn {
    font-size: 13px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: var(--radius);
    background: var(--accent-strong);
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn:hover {
    background: var(--accent);
  }
  .aff {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 5px;
    background: var(--ok-bg);
    color: var(--ok-text);
    white-space: nowrap;
  }
  .no-aff {
    font-size: 11px;
    color: var(--text-3);
    white-space: nowrap;
  }
</style>
