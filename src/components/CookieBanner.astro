<div id="cookie-banner" class="cookie-banner">
  <p class="cookie-text">
    Usamos solo cookies técnicas necesarias para que el sitio funcione. Si en el futuro añadimos cookies
    analíticas, estarán desactivadas hasta que las aceptes expresamente. Más info en la{" "}
    <a href="/politica-cookies">Política de Cookies</a>.
  </p>
  <div class="cookie-actions">
    <button id="cookie-reject" class="cookie-btn cookie-btn-outline" type="button">Rechazar no esenciales</button>
    <button id="cookie-accept" class="cookie-btn cookie-btn-solid" type="button">Aceptar todas</button>
  </div>
</div>

<style>
  .cookie-banner {
    display: none;
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: 16px;
    z-index: 100;
    max-width: 720px;
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    padding: 18px 20px;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .cookie-text {
    flex: 1 1 340px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-2);
  }
  .cookie-text a {
    color: var(--accent);
    text-decoration: underline;
  }
  .cookie-actions {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }
  .cookie-btn {
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 18px;
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--dur-fast) var(--ease);
  }
  .cookie-btn-solid {
    border: 1px solid var(--text);
    background: var(--text);
    color: #fff;
  }
  .cookie-btn-solid:hover {
    background: var(--accent);
    border-color: var(--accent);
  }
  .cookie-btn-outline {
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--text);
  }
  .cookie-btn-outline:hover {
    border-color: var(--text);
    background: var(--surface-2);
  }
</style>

<script>
  import { getConsent, setConsent } from "../scripts/cookies";

  const banner = document.getElementById("cookie-banner") as HTMLElement | null;
  const acceptBtn = document.getElementById("cookie-accept");
  const rejectBtn = document.getElementById("cookie-reject");

  if (banner && !getConsent()) {
    banner.style.display = "flex";
  }

  function hideBanner() {
    if (banner) banner.style.display = "none";
  }

  acceptBtn?.addEventListener("click", () => {
    setConsent(true);
    hideBanner();
  });

  rejectBtn?.addEventListener("click", () => {
    setConsent(false);
    hideBanner();
  });
</script>
