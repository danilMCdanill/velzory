---
import type { Raffle } from "../data/types";

interface Props {
  raffle: Raffle;
}

const { raffle } = Astro.props;
---

<div class="card">
  <div class="card-img" style={raffle.image ? `background-image:url('${raffle.image}')` : undefined}>
    {!raffle.image && "👟"}
  </div>
  <div class="card-body">
    <div class="card-top">
      <div>
        <p class="card-title">{raffle.title}</p>
        <p class="card-sub">{raffle.brand} · {raffle.price}</p>
      </div>
      <span class:list={["badge", raffle.status.type]}>{raffle.status.text}</span>
    </div>
    <div class="stores">
      <p class="stores-label">Disponible en:</p>
      {
        raffle.stores.map((store) => (
          <div class="store-row">
            <a
              class="store-name"
              href={store.url}
              target="_blank"
              rel={store.affiliate ? "sponsored noopener" : "noopener"}
            >
              {store.name}
            </a>
            {store.affiliate ? <span class="aff">Afiliado</span> : <span class="no-aff">Enlace directo</span>}
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .card-img {
    height: 130px;
    background: var(--surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    background-size: cover;
    background-position: center;
  }
  .card-body {
    padding: 14px;
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }
  .card-title {
    font-size: 15px;
    font-weight: 600;
  }
  .card-sub {
    font-size: 13px;
    color: var(--text-2);
    margin-top: 2px;
  }
  .badge {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .badge.warn {
    background: var(--warn-bg);
    color: var(--warn-text);
  }
  .badge.accent {
    background: var(--accent-bg);
    color: var(--accent-text);
  }
  .stores {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .stores-label {
    font-size: 12px;
    color: var(--text-3);
    margin-bottom: 8px;
  }
  .store-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 7px;
  }
  .store-row:last-child {
    margin-bottom: 0;
  }
  .store-name {
    font-size: 13px;
    color: var(--text);
    text-decoration: none;
  }
  .store-name:hover {
    text-decoration: underline;
  }
  .aff {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 5px;
    background: var(--ok-bg);
    color: var(--ok-text);
  }
  .no-aff {
    font-size: 11px;
    color: var(--text-3);
  }
</style>
