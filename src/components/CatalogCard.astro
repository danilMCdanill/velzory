---
import type { CatalogProduct } from "../data/types";

interface Props {
  product: CatalogProduct;
}

const { product } = Astro.props;
const rel = product.affiliate ? "sponsored noopener" : "noopener";
---

<div class="card">
  <a class="card-img" href={product.url} target="_blank" rel={rel} style={product.image ? `background-image:url('${product.image}')` : undefined}>
    {!product.image && "👟"}
  </a>
  <div class="card-body">
    <a class="card-title" href={product.url} target="_blank" rel={rel}>{product.title}</a>
    {product.colorway && <p class="card-sub">{product.colorway}</p>}

    <div class="card-meta">
      <span class="price">{product.price}</span>
      {product.styleCode && <span class="code">{product.styleCode}</span>}
    </div>

    <div class="card-action">
      <a class="btn" href={product.url} target="_blank" rel={rel}>Comprar en adidas ↗</a>
      {product.affiliate && <span class="aff">Afiliado</span>}
    </div>
  </div>
</div>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .card-img {
    height: 130px;
    background: var(--surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    background-blend-mode: multiply;
    text-decoration: none;
  }
  .card-body {
    padding: 14px;
  }
  .card-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    display: block;
  }
  .card-title:hover {
    text-decoration: underline;
  }
  .card-sub {
    font-size: 12px;
    color: var(--text-2);
    margin-top: 2px;
  }
  .card-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    margin-top: 10px;
  }
  .price {
    font-size: 18px;
    font-weight: 600;
  }
  .code {
    font-size: 11px;
    color: var(--text-3);
  }
  .card-action {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
  }
  .btn {
    font-size: 13px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: var(--radius);
    background: var(--accent-strong);
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn:hover {
    background: var(--accent);
  }
  .aff {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 5px;
    background: var(--ok-bg);
    color: var(--ok-text);
    white-space: nowrap;
  }
</style>
