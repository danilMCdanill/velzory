---
---

<header>
  <a class="logo" href="/">
    <div class="logo-mark">D</div>
    <div class="logo-name">DropAlert ES</div>
  </a>
</header>

<style>
  header {
    display: flex;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }
  .logo-mark {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: var(--accent-bg);
    color: var(--accent-text);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }
  .logo-name {
    font-size: 19px;
    font-weight: 600;
  }
</style>
